// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  icon        String
  color       String
  description String?
  events      Event[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Region {
  id              String   @id @default(cuid())
  name            String   @unique
  slug            String   @unique
  description     String?
  latitude        Float
  longitude       Float
  zoom            Int      @default(8)
  events          Event[]  @relation("PrimaryRegion")
  secondaryEvents Event[]  @relation("SecondaryRegion")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Tag {
  id          String     @id @default(cuid())
  name        String     @unique
  slug        String     @unique
  icon        String?
  color       String     @default("#3B82F6")
  description String?
  events      EventTag[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Event {
  id              String    @id @default(cuid())
  title           String
  slug            String    @unique
  description     String
  longDescription String?
  venue           String
  address         String
  latitude        Float     @default(25.7617)
  longitude       Float     @default(-80.1918)
  startDate       DateTime
  endDate         DateTime?
  price           Float?
  priceRange      String?
  imageUrl        String?
  website         String?
  phone           String?
  rating          Float     @default(0)
  reviewCount     Int       @default(0)
  viewCount       Int       @default(0)
  isFeatured      Boolean   @default(false)
  isActive        Boolean   @default(true)

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  regionId          String
  region            Region  @relation("PrimaryRegion", fields: [regionId], references: [id])
  secondaryRegionId String?
  secondaryRegion   Region? @relation("SecondaryRegion", fields: [secondaryRegionId], references: [id])

  tags            EventTag[]
  interactions    UserInteraction[]
  sponsoredEvents SponsoredEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Performance indexes
  @@index([categoryId])
  @@index([regionId])
  @@index([secondaryRegionId])
  @@index([startDate])
  @@index([isFeatured])
  @@index([isActive])
  @@index([isActive, isFeatured, startDate])
  @@index([latitude, longitude])
}

model EventTag {
  eventId String
  tagId   String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  tag     Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([eventId, tagId])
}

model UserInteraction {
  id        String   @id @default(cuid())
  userId    String   @default("guest")
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  action    String   // "swipe_right" or "swipe_left"
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([eventId])
  @@index([createdAt])
}

enum SponsorTier {
  BRONZE
  SILVER
  GOLD
}

model Sponsor {
  id               String            @id @default(cuid())
  name             String
  email            String            @unique
  logoUrl          String?
  website          String?
  description      String?
  tier             SponsorTier       @default(BRONZE)
  isActive         Boolean           @default(true)
  billingEmail     String?
  phone            String?
  contactName      String?
  monthlyBudget    Float             @default(50)
  sponsoredEvents  SponsoredEvent[]
  analytics        SponsorAnalytic[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([tier])
  @@index([isActive])
}

model SponsoredEvent {
  id              String   @id @default(cuid())
  sponsorId       String
  sponsor         Sponsor  @relation(fields: [sponsorId], references: [id], onDelete: Cascade)
  eventId         String
  event           Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  placementType   String   @default("featured") // "featured", "top", "promoted"
  priority        Int      @default(0) // Higher number = higher placement
  startDate       DateTime @default(now())
  endDate         DateTime?
  isActive        Boolean  @default(true)
  impressions     Int      @default(0)
  clicks          Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([sponsorId, eventId])
  @@index([eventId])
  @@index([sponsorId])
  @@index([isActive])
  @@index([priority])
}

model SponsorAnalytic {
  id          String   @id @default(cuid())
  sponsorId   String
  sponsor     Sponsor  @relation(fields: [sponsorId], references: [id], onDelete: Cascade)
  eventId     String?  // Nullable for sponsor-level analytics
  metric      String   // "impression", "click", "conversion"
  value       Int      @default(1)
  metadata    String?  // JSON string for additional data
  createdAt   DateTime @default(now())

  @@index([sponsorId])
  @@index([eventId])
  @@index([metric])
  @@index([createdAt])
}
